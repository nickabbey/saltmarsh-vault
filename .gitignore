# --- Quartz: build artifacts, deps, plugin cache (not committed) ---
node_modules/
public/
.quartz/
.quartz-cache/
tsconfig.tsbuildinfo
prof/

# --- Campaign images: never commit binaries (rewritten to external URLs at build) ---
content/**/*.png
content/**/*.jpg
content/**/*.jpeg
content/**/*.gif
content/**/*.webp

# --- Obsidian per-machine state (the live vault is content/; root .obsidian is defunct) ---
/.obsidian/
**/workspace.json
**/workspace-mobile.json
content/.obsidian/plugins/

# --- Misc ---
.trash/
.DS_Store
.claude/settings.local.json
